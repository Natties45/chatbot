# === Dify ===
DIFY_IMAGE_TAG=0.15.3
DIFY_SECRET_KEY=
DIFY_INIT_PASSWORD=
DIFY_DB_PASSWORD=
DIFY_REDIS_PASSWORD=
DIFY_WEB_PUBLIC_PORT=80
DIFY_WEB_TLS_PORT=443
DIFY_API_PORT=5001
DIFY_HOST=

# === Ollama local (embeddings) ===
OLLAMA_IMAGE_TAG=0.3.6
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_PORT=11434

# === Ollama Cloud Pro (LLM) — ใส่ใน Dify UI ไม่ใช่ที่นี่ ===
# OLLAMA_CLOUD_ENDPOINT=
# OLLAMA_CLOUD_API_KEY=
# OLLAMA_CLOUD_MODEL=qwen2.5

# === n8n ===
N8N_IMAGE_TAG=n8nio/n8n:1.55.0
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=
N8N_ENCRYPTION_KEY=
N8N_DB_PASSWORD=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# === Reverse proxy ===
CADDY_PUBLIC_HOST=

# === Backup ===
BACKUP_DIR=/var/backups/ols-chatbot
BACKUP_RETENTION_DAYS=14
